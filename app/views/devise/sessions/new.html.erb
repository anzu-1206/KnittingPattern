<%= stylesheet_link_tag "sessions_new", "data-turbo-track": "reload" %>

<div class="body">
  <div class="sessions-new">
    <div class="login-head">
      <h2 class="login-title">ログイン</h2>
      <p class="login-text">アカウント情報を入力してログインしてください</p>
    </div>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
      <div class="field">
        <p class="p-label"><%= f.label :email, "メールアドレス", :class => "label" %></p>
        <p class="p-field"><%= f.email_field :email, placeholder: "メールアドレスを入力", autofocus: true, autocomplete: "email", :class => "text-field" %></p>
      </div>

      <div class="field">
        <p class="p-label"><%= f.label :password, "パスワード", :class => "label" %></p>
        <p class="p-field"><%= f.password_field :password, placeholder: "パスワードを入力", autocomplete: "current-password", :class => "text-field" %></p>
      </div>



      <div class="actions">
        <ul class="buttons">
          <li class="btn"><%= f.submit "ログイン", :class => "to-login" %></li>
          <li class="btn">または</li>
          <li class="btn">アカウントをお持ちでないですか？　<%= link_to "新規登録する", new_user_registration_path, :class => "to-new" %></li>
        </ul>
      </div>
    <% end %>

  </div>

</div>

<%= render "shared/footer" %>
