<%= stylesheet_link_tag "patterns_index", "data-turbo-track": "reload" %>

<div class="dashboard-container">
    <div class="header-section">
        <h1>My Patterns</h1>
        <%= link_to "+ New Pattern", new_pattern_path, class: "new-pattern-btn-header" %>
    </div>

    <%= turbo_frame_tag "patterns-list" do %>

    <div class="search-pills">
        <%= search_form_for @q do |f| %>
            <%= f.search_field :title_cont, placeholder: "タイトルを検索", :class => "search-bar" %>
            <%= f.submit "検索", :class => "search-btn" %>
        <% end %>
        <div class="filter-pills">
            <%= link_to "すべて", patterns_path, class: "pill #{'active' if params[:category].blank?}" %>
            <%= link_to "キャラクター", patterns_path(category: "キャラクター"), class: "pill #{'active' if params[:category] == 'キャラクター'}" %>
            <%= link_to "動物・生き物", patterns_path(category: "動物・生き物"), class: "pill #{'active' if params[:category] == '動物・生き物'}" %>
            <%= link_to "お花・植物", patterns_path(category: "お花・植物"), class: "pill #{'active' if params[:category] == 'お花・植物'}" %>
            <%= link_to "幾何学・ノルディック", patterns_path(category: "幾何学・ノルディック"), class: "pill #{'active' if params[:category] == '幾何学・ノルディック'}" %>
            <%= link_to "冬小物", patterns_path(category: "冬小物"), class: "pill #{'active' if params[:category] == '冬小物'}" %>
            <%= link_to "その他", patterns_path(category: "その他"), class: "pill #{'active' if params[:category] == 'その他'}" %>
        </div>
    </div>


    <div class="patterns-grid">

        <% @patterns.each do |pattern| %>
        <div class="pattern-card">
            
            <div class="card-image">
                <% if pattern.image.attached? %>
                    <%= image_tag pattern.image, style: "width: 100%; height: 100%; object-fit: contain;" %>
                <% else %>
                    <div class="placeholder-pattern"></div>
                <% end %>
                
                <span class="status-badge">
                    <% if pattern.is_public %>
                    <span>公開中</span>
                    <% else %>
                    <span>非公開</span>
                    <% end %>
                </span>
            </div>

            <div class="card-content">
                <h3 class="card-title"><%= pattern.title %></h3>
                
                <p class="card-meta">
                    <i class="time-icon">⏰</i> 
                    <%= pattern.updated_at.to_fs(:datetime_jp) %>
                </p>

                <div class="card-actions">
                    <%= link_to "Edit", edit_pattern_path(pattern), class: "btn-edit", data: { turbo_frame: "_top" } %>
                    <%= link_to "Show", pattern_path(pattern), class: "btn-edit", data: { turbo_frame: "_top" } %>
                    <%= link_to "🗑", pattern_path(pattern), data: { turbo_method: :delete, turbo_confirm: "本当に削除しますか？" }, class: "btn-icon delete" %>
                </div>
            </div>

        </div>
        <% end %>

    </div>
    <% end %>
</div>

<%= render "shared/footer" %>

